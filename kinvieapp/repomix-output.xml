        <div className="bg-white/60 backdrop-blur-2xl p-4 md:p-6 rounded-[2rem] border border-blue-100 shadow-[0_8px_30px_rgba(59,130,246,0.05)] mb-8 flex flex-col lg:flex-row gap-4 items-center relative z-20">
