  const filteredPate = pateProducts.filter(p =>
    (p.name || '').toLowerCase().includes(searchQuery.toLowerCase())
  );

  return (
    <div className="animate-fade-in min-h-screen bg-[#F8F9FA] pb-16 relative overflow-hidden selection:bg-pink-200">
