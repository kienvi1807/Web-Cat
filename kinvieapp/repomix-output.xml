@import "tailwindcss";
@custom-variant dark (&:where(.dark, .dark *));

:root {
  --background: #fffbfc;
  --foreground: #1c1917;
  --card: #ffffff;
  --card-foreground: #1c1917;
  --primary: #e11d48;
  --primary-foreground: #ffffff;
  --secondary: #fecdd3;
  --secondary-foreground: #9f1239;
  --muted: #fdf2f4;
  --muted-foreground: #78716c;
  --accent: #fff1f2;
  --accent-foreground: #be123c;
  --border: #fce7f3;
  --ring: #fda4af;
  --radius: 1.5rem;
}

@layer utilities {
  .custom-scrollbar::-webkit-scrollbar { width: 6px; height: 8px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: #e7e5e4; border-radius: 10px; }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #d6d3d1; }
}

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --color-card: var(--card);
  --color-card-foreground: var(--card-foreground);
  --color-primary: var(--primary);
  --color-primary-foreground: var(--primary-foreground);
  --color-secondary: var(--secondary);
  --color-secondary-foreground: var(--secondary-foreground);
  --color-muted: var(--muted);
  --color-muted-foreground: var(--muted-foreground);
  --color-accent: var(--accent);
  --color-accent-foreground: var(--accent-foreground);
  --color-border: var(--border);
  --color-ring: var(--ring);
  --font-sans: var(--font-geist-sans);
  --font-mono: var(--font-geist-mono);
  --radius-lg: var(--radius);
  --radius-md: calc(var(--radius) - 0.5rem);
  --radius-sm: calc(var(--radius) - 1rem);
}

html {
  /* 🎯 Chặn tràn ngang toàn site: nếu bất kỳ phần tử nào (do lỡ đặt width cố
     định bằng px, hoặc chữ dài không được phép xuống dòng) bị rộng hơn màn
     hình, trình duyệt sẽ cắt bớt thay vì đẻ ra thanh cuộn ngang / đẩy layout
     lệch sang phải trên điện thoại. */
  overflow-x: hidden;
  width: 100%;
}

body {
  background: var(--background);
  color: var(--foreground);
  font-family: var(--font-sans), system-ui, sans-serif;
  overflow-x: hidden;
  width: 100%;
}

/* 🎯 Mặc định cho phép mọi chữ dài (tên khách, email, địa chỉ, số điện
   thoại dài...) tự xuống dòng đúng chỗ thay vì bị tràn ra ngoài khung.
   Những chỗ cố tình muốn giữ 1 dòng vẫn dùng class whitespace-nowrap
   như bình thường, không bị ảnh hưởng. */
* {
  overflow-wrap: break-word;
  word-break: break-word;
}

/* 🎯 Ảnh/video mặc định không bao giờ được vượt quá chiều rộng khung chứa */
@layer base {
  img, svg, video {
    max-width: 100%;
    height: auto;
  }
}

/* Smooth transitions for all interactive elements
   🎯 FIX PERFORMANCE: trước đây áp cho MỌI phần tử (kể cả từng <path> trong
   svg hoa văn, vệt gió, node dây leo...) -> trình duyệt phải theo dõi hàng
   trăm phần tử để sẵn sàng transition dù chúng chẳng bao giờ transition.
   Loại trừ toàn bộ svg và con của nó ra khỏi rule này (icon/hoa văn dùng CSS
   animation riêng hoặc đứng yên, không cần transition-property). */
*:not(svg, svg *) {
  transition-property: color, background-color, border-color, box-shadow, transform, opacity;
  transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
}

/* Ép tất cả các nút bấm và thẻ a đều hiện hình bàn tay */
button, a, [role="button"] {
  cursor: pointer !important;
}

.liquid-ether-container {
  position: relative;
  overflow: hidden;
  width: 100%;
  height: 100%;
  touch-action: pan-x pan-y;
}

.evil-eye-container {
  width: 100%;
  height: 100%;
}

body.tab-hidden * {
  animation-play-state: paused !important;
}
