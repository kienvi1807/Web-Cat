);

export default function Footer() {
  // 🌟 STATE THÔNG TIN LIÊN HỆ / MẠNG XÃ HỘI (ĐỌC TỪ DASHBOARD CÀI ĐẶT)
  const [settings, setSettings] = useState(DEFAULT_SETTINGS);

  useEffect(() => {
    supabase
      .from('system_settings')
      .select('hotline, zalo, email, facebook_url, facebook_cattery_url, tiktok_url, instagram_url')
      .eq('id', 1)
      .maybeSingle()
      .then(({ data }) => {
        if (data) {
          setSettings(prev => ({
            ...prev,
            hotline: data.hotline || prev.hotline,
            zalo: data.zalo || prev.zalo,
            email: data.email || prev.email,
            facebook_url: data.facebook_url || prev.facebook_url,
            facebook_cattery_url: data.facebook_cattery_url || prev.facebook_cattery_url,
            tiktok_url: data.tiktok_url || prev.tiktok_url,
            instagram_url: data.instagram_url || prev.instagram_url,
          }));
        }
      });
  }, []);

  // 🌟 KHAI BÁO STATE CHO NÚT "QUAY VỀ ĐẦU TRANG"
  const [showTopBtn, setShowTopBtn] = useState(false);

  // 🌟 RADAR THEO DÕI CUỘN CHUỘT
  useEffect(() => {
    const handleScroll = () => {
      // Nếu cuộn xuống quá 400px thì hiện nút, ngược lại thì ẩn
      if (window.scrollY > 400) {
        setShowTopBtn(true);
      } else {
        setShowTopBtn(false);
      }
    };

    window.addEventListener('scroll', handleScroll);
    return () => window.removeEventListener('scroll', handleScroll);
  }, []);

  // 🌟 HÀM CUỘN LÊN ĐẦU TRANG MƯỢT MÀ
  const scrollToTop = () => {
    window.scrollTo({
      top: 0,
      behavior: 'smooth'
    });
  };

  // Hàm kích hoạt pháo hoa
  const fireConfetti = async () => {
    const confetti = (await import('canvas-confetti')).default;

    const end = Date.now() + 1.5 * 1000;
    const colors = ['#ec4899', '#f43f5e', '#ffffff', '#fbcfe8'];

    (function frame() {
      confetti({ particleCount: 5, angle: 60, spread: 55, origin: { x: 0 }, colors: colors });
